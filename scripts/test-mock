#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

MOCK_HOST="${MOCK_HOST:-127.0.0.1}"
MOCK_PORT="${MOCK_PORT:-4010}"
TEST_API_BASE_URL="${TEST_API_BASE_URL:-http://${MOCK_HOST}:${MOCK_PORT}}"

MOCK_LOG="$(mktemp -t apollo-sdk-prism.XXXXXX.log)"

cleanup() {
  if [[ -n "${MOCK_PID:-}" ]] && kill -0 "$MOCK_PID" >/dev/null 2>&1; then
    kill "$MOCK_PID" >/dev/null 2>&1 || true
    wait "$MOCK_PID" >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT

TEST_API_BASE_URL="$TEST_API_BASE_URL" ./scripts/mock >"$MOCK_LOG" 2>&1 &
MOCK_PID=$!

for _ in $(seq 1 120); do
  if curl -s -o /dev/null "${TEST_API_BASE_URL}/people/match"; then
    break
  fi

  if ! kill -0 "$MOCK_PID" >/dev/null 2>&1; then
    echo "Mock server exited early. Log:" >&2
    cat "$MOCK_LOG" >&2
    exit 1
  fi

  sleep 0.25
done

if ! curl -s -o /dev/null "${TEST_API_BASE_URL}/people/match"; then
  echo "Mock server did not become ready in time. Log:" >&2
  cat "$MOCK_LOG" >&2
  exit 1
fi

TEST_API_BASE_URL="$TEST_API_BASE_URL" ./scripts/test "$@"
